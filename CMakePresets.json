{
    "version": 2,
    "configurePresets": [
        {
            "name": "build-optimization",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "ENABLE_FASTER_BUILD": true
            }
        },
        {
            "name": "ccache",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_C_COMPILER_LAUNCHER": {
                    "type": "STRING",
                    "value": "ccache"
                },
                "CMAKE_CXX_COMPILER_LAUNCHER": {
                    "type": "STRING",
                    "value": "ccache"
                }
            }
        },
        {
            "name": "clang",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        },
        {
            "name": "linker-mold",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_EXE_LINKER_FLAGS": {
                    "type": "STRING",
                    "value": "-fuse-ld=mold"
                },
                "CMAKE_MODULE_LINKER_FLAGS": {
                    "type": "STRING",
                    "value": "-fuse-ld=mold"
                },
                "CMAKE_SHARED_LINKER_FLAGS": {
                    "type": "STRING",
                    "value": "-fuse-ld=mold"
                }
            }
        },
        {
            "name": "linker-lld",
            "description": "Changes linker to LLD",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_EXE_LINKER_FLAGS": {
                    "type": "STRING",
                    "value": "-fuse-ld=lld"
                },
                "CMAKE_MODULE_LINKER_FLAGS": {
                    "type": "STRING",
                    "value": "-fuse-ld=lld"
                },
                "CMAKE_SHARED_LINKER_FLAGS": {
                    "type": "STRING",
                    "value": "-fuse-ld=lld"
                }
            }
        },
        {
            "name": "disabler",
            "hidden": true,
            "description": "Disables options that are not used by default presets",
            "cacheVariables": {
                "ENABLE_CPPLINT": false,
                "ENABLE_LTO": false
            }
        },
        {
            "name": "build-base",
            "hidden": true,
            "inherits": ["build-optimization", "disabler"],
            "cacheVariables": {
                "ENABLE_DEVELOPER_BUILD": false
            }
        },
        {
            "name": "developer-build-base",
            "hidden": true,
            "inherits": ["build-optimization", "disabler", "ccache"],
            "cacheVariables": {
                "ENABLE_DEVELOPER_BUILD": true,
                "ENABLE_TESTS": true,
                "ENABLE_PRIVATE_TESTS": true,
                "ENABLE_FUNCTIONAL_TESTS": true,
                "ENABLE_NPU_MICRO_BENCHMARKS": true,
                "ENABLE_SPLIT_DWARF": true,
                "LIT_TESTS_USE_LINKS": true,
                "CMAKE_EXPORT_COMPILE_COMMANDS" : true
            }
        },
        {
            "name": "build-release",
            "description": "Release build for NPU Compiler. Requires Ninja",
            "displayName": "Default Release build",
            "inherits": ["build-base"],
            "binaryDir": "${sourceDir}/build-x86_64/Release",
            "cacheVariables": {
                "OpenVINODeveloperPackage_DIR": {
                    "type": "FILEPATH",
                    "value": "$env{OPENVINO_HOME}/build-x86_64/Release"
                },
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "Release"
                }
            }
        },
        {
            "name": "build-debug",
            "description": "Debug build for NPU Compiler. Requires Ninja",
            "displayName": "Default Debug build",
            "inherits": ["build-base"],
            "binaryDir": "${sourceDir}/build-x86_64/Debug",
            "cacheVariables": {
                "OpenVINODeveloperPackage_DIR": {
                    "type": "FILEPATH",
                    "value": "$env{OPENVINO_HOME}/build-x86_64/Debug"
                },
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "Debug"
                }
            }
        },
        {
            "name": "build-relwithdebinfo",
            "description": "RelWithDebInfo build for NPU Compiler. Requires Ninja",
            "displayName": "Default RelWithDebInfo build",
            "inherits": ["build-base"],
            "binaryDir": "${sourceDir}/build-x86_64/RelWithDebInfo",
            "cacheVariables": {
                "OpenVINODeveloperPackage_DIR": {
                    "type": "FILEPATH",
                    "value": "$env{OPENVINO_HOME}/build-x86_64/RelWithDebInfo"
                },
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "RelWithDebInfo"
                }
            }
        },
        {
            "name": "developer-build-release",
            "description": "Release build for NPU Compiler development. Enables developer build, tests. Requires Ninja and ccache",
            "displayName": "Developer Release build",
            "inherits": ["developer-build-base"],
            "binaryDir": "${sourceDir}/build-x86_64/Release",
            "cacheVariables": {
                "OpenVINODeveloperPackage_DIR": {
                    "type": "FILEPATH",
                    "value": "$env{OPENVINO_HOME}/build-x86_64/Release"
                },
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "Release"
                }
            }
        },
        {
            "name": "developer-build-debug",
            "description": "Debug build for NPU Compiler development. Enables developer build, tests. Requires Ninja and ccache",
            "displayName": "Developer Debug build",
            "inherits": ["developer-build-base"],
            "binaryDir": "${sourceDir}/build-x86_64/Debug",
            "cacheVariables": {
                "OpenVINODeveloperPackage_DIR": {
                    "type": "FILEPATH",
                    "value": "$env{OPENVINO_HOME}/build-x86_64/Debug"
                },
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "Debug"
                }
            }
        },
        {
            "name": "developer-build-relwithdebinfo",
            "description": "RelWithDebInfo build for NPU Compiler development. Enables developer build, tests. Requires Ninja and ccache",
            "displayName": "Developer RelWithDebInfo build",
            "inherits": ["developer-build-base"],
            "binaryDir": "${sourceDir}/build-x86_64/RelWithDebInfo",
            "cacheVariables": {
                "OpenVINODeveloperPackage_DIR": {
                    "type": "FILEPATH",
                    "value": "$env{OPENVINO_HOME}/build-x86_64/RelWithDebInfo"
                },
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "RelWithDebInfo"
                }
            }
        },
        {
            "name": "developer-build-fast-release",
            "description": "Release build for NPU Compiler development. Enables developer build, tests. Requires Ninja, ccache, Clang and mold",
            "displayName": "Developer Release build using Clang and mold",
            "inherits": ["developer-build-base", "clang", "linker-mold"],
            "binaryDir": "${sourceDir}/build-x86_64/Release",
            "cacheVariables": {
                "OpenVINODeveloperPackage_DIR": {
                    "type": "FILEPATH",
                    "value": "$env{OPENVINO_HOME}/build-x86_64/Release"
                },
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "Release"
                }
            }
        },
        {
            "name": "developer-build-fast-debug",
            "description": "Debug build for NPU Compiler development. Enables developer build, tests. Requires Ninja, ccache, Clang and mold",
            "displayName": "Developer Debug build using Clang and mold",
            "inherits": ["developer-build-base", "clang", "linker-mold"],
            "binaryDir": "${sourceDir}/build-x86_64/Debug",
            "cacheVariables": {
                "OpenVINODeveloperPackage_DIR": {
                    "type": "FILEPATH",
                    "value": "$env{OPENVINO_HOME}/build-x86_64/Debug"
                },
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "Debug"
                }
            }
        },
        {
            "name": "developer-build-fast-relwithdebinfo",
            "description": "RelWithDebInfo build for NPU Compiler development. Enables developer build, tests. Requires Ninja, ccache, Clang and mold",
            "displayName": "Developer RelWithDebInfo build using Clang and mold",
            "inherits": ["developer-build-base", "clang", "linker-mold"],
            "binaryDir": "${sourceDir}/build-x86_64/RelWithDebInfo",
            "cacheVariables": {
                "OpenVINODeveloperPackage_DIR": {
                    "type": "FILEPATH",
                    "value": "$env{OPENVINO_HOME}/build-x86_64/RelWithDebInfo"
                },
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "RelWithDebInfo"
                }
            }
        },

        {
            "name": "ov-npu-developer-base",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS" : true,

                "ENABLE_HETERO": true,
                "ENABLE_INTEL_CPU": true,
                "ENABLE_INTEL_GPU": false,
                "ENABLE_TEMPLATE": true,

                "ENABLE_INTEL_NPU_COMPILER": false,

                "ENABLE_OV_ONNX_FRONTEND": false,
                "ENABLE_OV_PADDLE_FRONTEND": false,
                "ENABLE_OV_PYTORCH_FRONTEND": false,
                "ENABLE_OV_TF_FRONTEND": false,
                "ENABLE_OV_TF_LITE_FRONTEND": false,

                "THREADING": {
                    "type": "STRING",
                    "value": "TBB"
                },
                "ENABLE_LTO": false,
                "ENABLE_OPENCV": true,

                "ENABLE_TESTS": true,
                "ENABLE_PRIVATE_TESTS": true,
                "ENABLE_FUNCTIONAL_TESTS": true,

                "OPENVINO_EXTRA_MODULES": {
                    "type": "FILEPATH",
                    "value": "./modules/vpux"
                }
            }
        },

        {
            "name": "ov-npu-developer-debug",
            "description": "Same as developer-build-debug, but it builds VPUX plugin in OpenVINO project tree. Please make sure that VPUX plugin is located inside OpenVINO repo in modules/vpux folder.",
            "binaryDir": "${sourceDir}/build-x86_64/Debug",
            "displayName": "OpenVINO + NPU Debug build",
            "inherits": ["ov-npu-developer-base", "developer-build-debug"]
        },
        {
            "name": "ov-npu-developer-release",
            "description": "Same as developer-build-release, but it builds VPUX plugin in OpenVINO project tree. Please make sure that VPUX plugin is located inside OpenVINO repo in modules/vpux folder.",
            "binaryDir": "${sourceDir}/build-x86_64/Release",
            "displayName": "OpenVINO + NPU Release build",
            "inherits": ["ov-npu-developer-base", "build-release"]
        },

        {
            "name": "cid-base",
            "hidden": true,
            "description": "Default configuration for NPU driver compiler. Make sure NPU_PLUGIN_HOME environment variable is set to the VPUX plugin root directory.",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": false,
                "ENABLE_OV_IR_FRONTEND": true,
                "THREADING": {
                    "type": "STRING",
                    "value": "TBB"
                },
                "ENABLE_TBBBIND_2_5": false,
                "BUILD_COMPILER_FOR_DRIVER": true,

                "OPENVINO_EXTRA_MODULES": {
                    "type": "FILEPATH",
                    "value": "$env{NPU_PLUGIN_HOME}"
                }
           }
        },
        {
            "name": "cid-linux",
            "description": "Default CMake configuration to build NPU-CiD targets on Linux. Note: (1) Make sure NPU_PLUGIN_HOME and CONFIG environment variables are set. (2) CiD is a static build that includes only the necessary targets. Irrelevant targets/components are excluded to minimize the size of the build output.",
            "binaryDir": "${sourceDir}/build_$env{CONFIG}",
            "displayName": "CID build for Linux",
            "inherits": ["cid-base", "build-optimization", "disabler", "ccache"],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "$env{CONFIG}"
                },

                "ENABLE_LTO": false,
                "ENABLE_FASTER_BUILD": false,
                "ENABLE_CPPLINT": false,

                "ENABLE_TESTS": false,
                "ENABLE_FUNCTIONAL_TESTS": false,
                "ENABLE_SAMPLES": false,

                "ENABLE_JS": false,

                "ENABLE_PYTHON": false,
                "ENABLE_PYTHON_PACKAGING": false,
                "ENABLE_WHEEL": false,

                "ENABLE_OV_ONNX_FRONTEND": false,
                "ENABLE_OV_PADDLE_FRONTEND": false,
                "ENABLE_OV_PYTORCH_FRONTEND": false,
                "ENABLE_OV_TF_FRONTEND": false,
                "ENABLE_OV_TF_LITE_FRONTEND": false,
                "ENABLE_OV_JAX_FRONTEND": false,

                "ENABLE_SYSTEM_TBB": false,
                "ENABLE_TBB_RELEASE_ONLY": false,
                "ENABLE_OPENCV": false,

                "ENABLE_MULTI": false,
                "ENABLE_HETERO": false,
                "ENABLE_AUTO": false,
                "ENABLE_AUTO_BATCH": false,
                "ENABLE_TEMPLATE": false,
                "ENABLE_PROXY": false,
                "ENABLE_INTEL_CPU": false,
                "ENABLE_INTEL_GPU": false,

                "ENABLE_NPU_PLUGIN_ENGINE": false,
                "ENABLE_ZEROAPI_BACKEND": false,
                "ENABLE_DRIVER_COMPILER_ADAPTER": false,
                "ENABLE_INTEL_NPU_INTERNAL": false,
                "ENABLE_INTEL_NPU_PROTOPIPE": false,

                "ENABLE_PRIVATE_TESTS": false,
                "ENABLE_NPU_LSP_SERVER": false
            }
        },
        {
            "name": "cid-windows",
            "description": "Default CMake configuration to build NPU-CiD targets on Windows. Note: (1) Make sure NPU_PLUGIN_HOME and CONFIG environment variables are set. (2) CiD is a static build that includes only the necessary targets. Irrelevant targets/components are excluded to minimize the size of the build output.",
            "binaryDir": "${sourceDir}/build_$env{CONFIG}",
            "displayName": "CID build for Windows",
            "inherits": ["cid-base", "build-optimization", "disabler", "ccache"],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "$env{CONFIG}"
                },
                "CMAKE_TOOLCHAIN_FILE":"${sourceDir}\\cmake\\toolchains\\onecoreuap.toolchain.cmake",
                "ENABLE_LTO": false,
                "ENABLE_FASTER_BUILD": false,
                "ENABLE_CPPLINT": false,

                "ENABLE_TESTS": false,
                "ENABLE_FUNCTIONAL_TESTS": false,
                "ENABLE_SAMPLES": false,

                "ENABLE_JS": false,

                "ENABLE_PYTHON": false,
                "ENABLE_PYTHON_PACKAGING": false,
                "ENABLE_WHEEL": false,

                "ENABLE_OV_ONNX_FRONTEND": false,
                "ENABLE_OV_PADDLE_FRONTEND": false,
                "ENABLE_OV_PYTORCH_FRONTEND": false,
                "ENABLE_OV_TF_FRONTEND": false,
                "ENABLE_OV_TF_LITE_FRONTEND": false,
                "ENABLE_OV_JAX_FRONTEND": false,

                "ENABLE_SYSTEM_TBB": false,
                "ENABLE_TBB_RELEASE_ONLY": false,
                "ENABLE_OPENCV": false,

                "ENABLE_MULTI": false,
                "ENABLE_HETERO": false,
                "ENABLE_AUTO": false,
                "ENABLE_AUTO_BATCH": false,
                "ENABLE_TEMPLATE": false,
                "ENABLE_PROXY": false,
                "ENABLE_INTEL_CPU": false,
                "ENABLE_INTEL_GPU": false,

                "ENABLE_NPU_PLUGIN_ENGINE": false,
                "ENABLE_ZEROAPI_BACKEND": false,
                "ENABLE_DRIVER_COMPILER_ADAPTER": false,
                "ENABLE_INTEL_NPU_INTERNAL": false,
                "ENABLE_INTEL_NPU_PROTOPIPE": false,

                "ENABLE_PRIVATE_TESTS": false,
                "ENABLE_NPU_LSP_SERVER": false
            }
        },
        {
            "name": "fuzzing-build",
            "description": "Build for executing fuzz tests. Enables sanitizers. Requires Ninja, clang, lld and ccache",
            "displayName": "Fuzz testing build",
            "inherits": ["developer-build-debug", "clang", "linker-lld"],
            "cacheVariables": {
                "ENABLE_SANITIZER": true,
                "ENABLE_FUZZING": true,
                "ENABLE_NPU_FUZZ_TESTS": true
            }
        }
    ],
    "testPresets": [
        {
            "name": "UnitTests",
            "configurePreset": "developer-build-debug",
            "filter": {
                "include": {
                    "name": "(npuUnitTests|LIT-NPU-ALL$)"
                }
            },
            "output": {
                "verbosity": "verbose"
            }
        },
        {
            "name": "NPU4000",
            "hidden": true,
            "environment": {
                "IE_KMB_TESTS_PLATFORM": "4000",
                "IE_KMB_TESTS_DEVICE_NAME": "NPU.4000",
                "SINGLE_IMAGE_TEST_CONFIG": "public_models_4000.json",
                "SINGLE_IMAGE_TEST_TOOLS": "compile_tool;NetTest-CalcRef;NetTest-Validate",
                "VPUX_PLUGIN_HOME": "${sourceDir}"
            }
        },
        {
            "name": "NPU3720",
            "hidden": true,
            "environment": {
                "IE_KMB_TESTS_PLATFORM": "3720",
                "IE_KMB_TESTS_DEVICE_NAME": "NPU.3720",
                "SINGLE_IMAGE_TEST_CONFIG": "public_models_3720.json",
                "SINGLE_IMAGE_TEST_TOOLS": "compile_tool;NetTest-CalcRef;NetTest-Validate",
                "VPUX_PLUGIN_HOME": "${sourceDir}"
            }
        },
        {
            "name": "Silicon",
            "hidden": true,
            "environment": {
            }
        },
        {
            "name": "NPU3720/Silicon",
            "hidden": true,
            "inherits": [
                "NPU3720",
                "Silicon"
            ],
            "configurePreset": "developer-build-debug",
            "output": {
                "verbosity": "verbose"
            },
            "filter": {
                "include": {
                    "name": "^(npuFuncTests|SingleImageTests)$"
                }
            }
        },
        {
            "name": "NPU4000/Silicon",
            "hidden": true,
            "inherits": [
                "NPU4000",
                "Silicon"
            ],
            "configurePreset": "developer-build-debug",
            "output": {
                "verbosity": "verbose"
            },
            "filter": {
                "include": {
                    "name": "^(npuFuncTests|SingleImageTests)$"
                }
            }
        }
    ]
}
